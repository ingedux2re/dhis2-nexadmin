{
  "name": "dhis2-nexadmin",
  "version": "1.1.0",
  "description": "DHIS2 NexAdmin — IS Administration Toolkit",
  "license": "BSD-3-Clause",
  "author": {
    "name": "ingedux",
    "url": "https://github.com/ingedux2re"
  },
  "scripts": {
    "prepare": "husky",
    "start": "d2-app-scripts start --proxy https://play.im.dhis2.org/stable-2-42-4",
    "build": "node scripts/build.js",
    "test": "d2-app-scripts test --jestConfig jest.config.js",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "i18n:extract": "d2-app-scripts i18n extract",
    "i18n:generate": "d2-app-scripts i18n generate",
    "postinstall": "node scripts/postinstall.js",
    "typecheck": "tsc --noEmit",
    "validate": "yarn typecheck && yarn lint && yarn format:check && yarn test --watchAll=false"
  },
  "dependencies": {
    "@dhis2/app-runtime": "^3.16.0",
    "@dhis2/d2-i18n": "^1.1.0",
    "@dhis2/ui": "^10.12.11",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@dhis2/app-service-data": "^3.10.0",
    "@dhis2/cli-app-scripts": "^12",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.3.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.0",
    "identity-obj-proxy": "^3.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --max-warnings 0",
      "prettier --write"
    ],
    "src/**/*.css": [
      "prettier --write"
    ]
  },
  "d2": {
    "app": {
      "name": "DHIS2 NexAdmin",
      "description": "IS Administration Toolkit — Org Units, Users, Governance & Analytics",
      "version": "1.1.0",
      "minDHIS2Version": "2.38"
    }
  },
  "resolutions": {
    "@dhis2/ui": "9.15.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "styled-jsx": "4.0.1"
  }
}
